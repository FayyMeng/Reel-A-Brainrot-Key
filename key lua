            StatusLabel.Text = "❌ Key cannot be empty!"
            StatusLabel.TextColor3 = Color3.fromRGB(200, 70, 70)
            return
        end
        
        StatusLabel.Text = "🔍 Verifying key..."
        StatusLabel.TextColor3 = Color3.fromRGB(240, 180, 50)
        
