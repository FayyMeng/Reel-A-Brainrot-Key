            if userKey == VALID_KEY then
                StatusLabel.Text = "✅ Key valid! Loading..."
                StatusLabel.TextColor3 = Color3.fromRGB(30, 140, 100)
                
                task.wait(1)
                ScreenGui:Destroy()
                
